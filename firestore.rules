// ⛔ DO NOT DEPLOY THIS FILE. It is intentionally NOT the live ruleset.
//
// All UNICO apps share ONE Firestore ruleset in the "unico-operations" project.
// The canonical, deployable source is:
//     /home/nishel/attendance-app/firestore.rules
//
// Deploy ONLY via:  node attendance-app/jobs/deployRules.js
// Inspect live:     node attendance-app/jobs/getRules.js
//
// This file is a STALE LOCAL COPY kept for reference only. It is narrower/older
// than the live rules and deploying it WOULD SILENTLY BREAK OTHER APPS
// (a missing rule = default-deny = data looks deleted).
//
// ── reference copy below this line ──────────────────────────────────────────

rules_version = '2';
// ────────────────────────────────────────────────────────────────────────────
// Firestore security rules for the "unico-operations" project.
// Paste these in: Firebase Console → Firestore Database → Rules → Publish.
//
// This single project hosts MULTIPLE apps, each under its own namespace:
//   • apps/platingjobwork/...   (Plating Job Work)
//   • apps/fitting/...  (Fitting Assembly  ← this app)
//
// Model: reading & writing day-to-day data requires being SIGNED IN (anonymous
// or Google) — keeps each app's data private to your team. Tighten later by
// pinning writes to specific Google account UIDs.
//
// NOTE: keep BOTH app blocks below so publishing these rules does not disable
// the other app. Add a new block when you add a new app.
// ────────────────────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    // Plating Job Work
    match /apps/platingjobwork/{collection}/{docId} {
      allow read, write: if request.auth != null;
    }
    match /apps/platingjobwork {
      allow read, write: if request.auth != null;
    }

    // Fitting Assembly
    match /apps/fitting/{collection}/{docId} {
      allow read, write: if request.auth != null;
    }
    match /apps/fitting {
      allow read, write: if request.auth != null;
    }

    // Everything else denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
